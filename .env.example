# Liminal AI Environment Configuration
# SECURITY WARNING: Never expose LIMINAL_LLM_BASE_URL to cloud metadata endpoints
# Only use trusted LLM providers

# LLM Provider Configuration
LIMINAL_LLM_PROVIDER=lmstudio
LIMINAL_LLM_BASE_URL=http://localhost:1234/v1
LIMINAL_LLM_MODEL=qwen2.5-coder-7b-instruct

# Optional: API keys for cloud providers
# OPENAI_API_KEY=sk-...
# MINIMAX_API_KEY=...

# ============================================
# SECURITY CONFIGURATION
# ============================================

# SSRF Protection
# Additional allowed hosts (comma-separated)
LIMINAL_ALLOWED_HOSTS=

# Allow localhost LLM connections (default: true)
LIMINAL_ALLOW_LOCALHOST_LLM=true

# Allow private IP ranges for LLM (DANGEROUS - default: false)
LIMINAL_ALLOW_PRIVATE_IP_LLM=false

# Sandbox Security
# Set to true ONLY in containerized environments with seccomp
LIMINAL_DISABLE_SANDBOX=false

# Rate Limiting
LIMINAL_RATE_LIMIT_GENERAL=100
LIMINAL_RATE_LIMIT_WINDOW_MINUTES=15
LIMINAL_RATE_LIMIT_EXPORT=10
LIMINAL_RATE_LIMIT_EXPORT_WINDOW_MINUTES=60
LIMINAL_RATE_LIMIT_SANDBOX=30
LIMINAL_RATE_LIMIT_SANDBOX_WINDOW_MINUTES=15
