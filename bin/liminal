else if (cmd === 'dream' && cmdArgs[0] === 'run') {
  const { DreamPlanner, RecombinationEngine } = await import('../dist/dreaming/index.js');
  const { LiminalFS } = await import('../dist/fs/index.js');
  const { EmergenceHooks } = await import('../dist/emergence/index.js');

  const strategy = cmdArgs[1] || 'auto';

  const liminalFs = LiminalFS.open(process.cwd());
  try {
    const hooks = new EmergenceHooks(liminalFs);
    const archive = hooks.getArchive();
    const cells = archive.getAllCells();
    const axes = ['order-chaos', 'sparse-dense', 'symmetry-asymmetry', 'smooth-bursty', 'static-evolving', 'harmonic-dissonant'];

    const planner = new DreamPlanner();
    const plan = planner.plan(cells, axes);

    if (plan.tasks.length === 0) {
      console.error('No dream tasks to plan — archive may be empty.');
      process.exit(1);
    }

    const engine = new RecombinationEngine();

    console.log('');
    console.log(`=== Dream Run (strategy: ${strategy}) ===`);
    console.log(`  Planned ${plan.tasks.length} dream tasks`);

    for (const task of plan.tasks.slice(0, 5)) {
      console.log(`  [${task.strategy}] priority=${task.priority.toFixed(1)} — ${task.reason}`);
      if (task.sources.length >= 2) {
        const result = engine.recombine(task.sources[0], task.sources[1]);
        console.log(`    → novelty=${result.noveltyScore.toFixed(3)} strategy=${result.strategy}`);
      }
    }
    console.log('');
  } finally {
    liminalFs.close();
  }
  process.exit(0);
}
else if (cmd === 'garden' && cmdArgs[0] === 'status') {
  const { GardenPolicy } = await import('../dist/autonomy/GardenPolicy.js');
  const { StagnationDetector } = await import('../dist/autonomy/StagnationDetector.js');
  const { LiminalFS } = await import('../dist/fs/index.js');
  const { EmergenceHooks } = await import('../dist/emergence/index.js');

  const liminalFs = LiminalFS.open(process.cwd());
  try {
    const hooks = new EmergenceHooks(liminalFs);
    const archive = hooks.getArchive();
