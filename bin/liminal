#!/usr/bin/env node
import dotenv from "dotenv";
dotenv.config();

import { run, PreviewServer, generateMusic, generateVisuals } from '../dist/index.js';
import { getEffectiveConfig, saveConfig, loadProjectConfig, getMultiModelConfig } from '../dist/config/ConfigLoader.js';
import { PromptHistory } from '../dist/config/PromptHistory.js';
import { InteractiveMode } from '../dist/tui/InteractiveMode.js';
import { CompostMill } from '../dist/compost/CompostMill.js';
import { parseArgs, execute } from '../dist/compost/cli.js';
import { LLMClient } from '../dist/llm/LLMClient.js';
import { ModelRouter } from '../dist/compost/ModelRouter.js';
import { chatCommand } from '../dist/chat/commands/chat.js';
import fs from 'fs';
import path from 'path';

// Load config and set env vars for LLMClient to pick up
async function initializeConfig() {
  const config = await getEffectiveConfig(undefined, process.cwd());
  
  // Set env vars so LLMClient picks them up
  process.env.LIMINAL_LLM_PROVIDER = config.provider;
  if (config.baseUrl) process.env.LIMINAL_LLM_BASE_URL = config.baseUrl;
  process.env.LIMINAL_LLM_MODEL = config.model;
  if (config.apiKey) process.env.LIMINAL_LLM_API_KEY = config.apiKey;
  
  return config;
}

// Initialize prompt history
const history = new PromptHistory();

const args = process.argv.slice(2);

// Parse flags
const flags = {};
let cmd = null;
let cmdArgs = [];
let prompt = null;
let maxIterations = 3;
let output = null;

for (let i = 0; i < args.length; i++) {
  const arg = args[i];
  if (arg === '--help' || arg === '-h') {
    flags.help = true;
  } else if (arg === '--version') {
    flags.version = true;
  } else if (arg === '--prompt' || arg === '-p') {
    flags.prompt = args[++i];
  } else if (arg === '--max-iterations' || arg === '-m') {
    flags.maxIterations = parseInt(args[++i]);
  } else if (arg === '--output' || arg === '-o') {
    flags.output = args[++i];
  } else if (arg === '--provider') {
    flags.provider = args[++i];
  } else if (arg === '--model') {
    flags.model = args[++i];
  } else if (arg === '--configure') {
    flags.configure = true;
  } else if (arg === '--recent') {
    const nextArg = args[i + 1];
    if (nextArg && !nextArg.startsWith('-') && !isNaN(parseInt(nextArg))) {
      flags.recent = parseInt(args[++i]);
    } else {
      flags.recent = 10;
    }
  } else if (arg === '--favorite') {
    flags.favorite = args[++i];
  } else if (arg === '--favorites') {
    flags.favorites = true;
  } else if (arg === '--interactive' || arg === '-i') {
    flags.interactive = true;
  } else if (arg === '--mode') {
    flags.mode = args[++i];
  } else if (arg === '--use-swarm') {
    flags.useSwarm = true;
  } else if (arg === '--swarm-mode') {
    flags.swarmMode = args[++i];
  } else if (arg === '--swarm-rounds') {
    flags.swarmRounds = parseInt(args[++i]);
  } else if (arg === '--fast-model') {
    flags.fastModel = args[++i];
  } else if (arg === '--powerful-model') {
    flags.powerfulModel = args[++i];
  } else if (arg === '--routing-mode') {
    flags.routingMode = args[++i];
  } else if (arg === '--confidence-threshold') {
    flags.confidenceThreshold = parseFloat(args[++i]);
  } else if (arg === '--spec') {
    flags.spec = args[++i];
  } else if (arg === '--verbose' || arg === '-v') {
    flags.verbose = true;
  } else if (!arg.startsWith('-')) {
    if (cmd === null) { cmd = arg; } else { cmdArgs.push(arg); }
  }
}

// Handle --help flag (global)
if (flags.help) {
  console.log('');
  console.log('🎨 Liminal: Creative Coding Agent');
  console.log('');
  console.log('USAGE:');
  console.log('  liminal [options] <command> [args]');
  console.log('');
  console.log('COMMANDS:');
  console.log('  generate, gen, g <prompt>   Create p5.js art from prompt');
  console.log('  serve, s [port]             Start preview server (default: 3456)');
  console.log('  list, ls                    Show saved sketches');
  console.log('  compost <subcommand>        Compost Mill: add, digest, soup, seeds, status');
  console.log('  composite                   Compose video layers from a JSON spec');
  console.log('  chat                        Start conversational creative coding mode');
  console.log('');
  console.log('OPTIONS:');
  console.log('  --prompt, -p <text>         Prompt for generation');
  console.log('  --max-iterations, -m <num>  Max iterations (default: 3)');
  console.log('  --output, -o <path>         Output directory');
  console.log('  --provider <name>           LLM provider (lmstudio, inception, ollama)');
  console.log('  --model <name>              Model name');
  console.log('  --configure                 Set up LM Studio config');
  console.log('  --recent [n]                Show recent prompts (default: 10)');
  console.log('  --favorite <prompt>         Add prompt to favorites');
  console.log('  --favorites                 List favorite prompts');
  console.log('  --interactive, -i           Interactive TUI mode');
  console.log('  --mode <mode>              Mode: live-music (generate Strudel/Hydra to --output)');
  console.log('  --use-swarm                Use Liminal swarm (7-persona Ollama) for generation');
  console.log('  --swarm-mode <mode>        Swarm mode: competitive, hybrid, ring, mesh (default: hybrid)');
  console.log('  --swarm-rounds <num>       Max swarm rounds (default: 10)');
  console.log('  --fast-model <name>        Primary/fast model for dual-mode (e.g., qwen3.5:9b)');
  console.log('  --powerful-model <name>     Secondary/powerful model (e.g., qwen3:30b-a3b)');
  console.log('  --routing-mode <mode>       Dual-model routing: cascade, speculative, ensemble, specialized');
  console.log('  --confidence-threshold <n>  Cascade escalation threshold (0-1, default: 0.8)');
  console.log('  --verbose, -v               Verbose output');
  console.log('  --help, -h                  Show this help message');
  console.log('  --version                   Show version');
  console.log('');
  console.log('EXAMPLES:');
  console.log('  liminal --prompt "blue particles"');
  console.log('  liminal --prompt "red circles" --provider lmstudio');
  console.log('  liminal --configure');
  console.log('  liminal serve 3456');
  console.log('  liminal list');
  console.log('');
  process.exit(0);
}

// Handle --version flag
if (flags.version) {
  console.log('Liminal v1.0.0');
  process.exit(0);
}

// Handle --configure flag
if (flags.configure) {
  console.log('');
  console.log('🎨 Liminal Configuration');
  console.log('');
  console.log('Setting up LM Studio config...');
  console.log('');
  
  const config = {
    defaultProvider: 'lmstudio',
    providers: {
      lmstudio: {
        baseUrl: 'http://localhost:1234/v1',
        model: 'local-model'
      }
    }
  };
  
  saveConfig(config).then(() => {
    console.log('✅ Config saved to ~/.liminal/config.json');
    console.log('');
    console.log('You can now run:');
    console.log('  liminal --prompt "your idea"');
    console.log('');
    process.exit(0);
  }).catch(err => {
    console.error('❌ Error saving config:', err.message);
    process.exit(1);
  });
  
  // Don't exit yet - wait for saveConfig
}

// Override config with CLI flags
if (flags.provider) {
  process.env.LIMINAL_LLM_PROVIDER = flags.provider;
  // Set appropriate baseUrl for the provider (overrides project config)
  const providerUrls = {
    'lmstudio': 'http://localhost:1234/v1',
    'inception': 'http://localhost:5000/v1',
    'ollama': 'http://localhost:11434',
    'openai': 'https://api.openai.com/v1',
    'minimax': 'https://api.minimax.io/v1',
    'hybrid': 'https://api.minimax.io/v1',
  };
  if (providerUrls[flags.provider]) {
    process.env.LIMINAL_LLM_BASE_URL = providerUrls[flags.provider];
  }
}
if (flags.model) {
  process.env.LIMINAL_LLM_MODEL = flags.model;
}

// Handle --interactive flag
if (flags.interactive) {
  const mode = new InteractiveMode(history);
  try {
    const { prompt: interactivePrompt, options } = await mode.run();
    flags.prompt = interactivePrompt;
    if (options.provider) {
      process.env.LIMINAL_LLM_PROVIDER = options.provider;
    }
  } catch (err) {
    console.error('Interactive mode cancelled');
    process.exit(0);
  }
}

// Handle --recent flag
if (flags.recent) {
  const recent = await history.getRecent(flags.recent);
  console.log('');
  console.log('🕐 Recent Prompts:');
  console.log('');
  if (recent.length === 0) {
    console.log('  (none yet)');
  } else {
    recent.forEach((p, i) => console.log('  ' + (i + 1) + '. ' + p));
  }
  console.log('');
  process.exit(0);
}

// Handle --favorites flag
if (flags.favorites) {
  const favorites = await history.getFavorites();
  console.log('');
  console.log('⭐ Favorite Prompts:');
  console.log('');
  if (favorites.length === 0) {
    console.log('  (none yet)');
  } else {
    favorites.forEach((p, i) => console.log('  ' + (i + 1) + '. ' + p));
  }
  console.log('');
  process.exit(0);
}

// Handle --favorite flag (add to favorites)
if (flags.favorite) {
  await history.addFavorite(flags.favorite);
  console.log('');
  console.log('⭐ Added to favorites: "' + flags.favorite + '"');
  console.log('');
  process.exit(0);
}

// Initialize config (loads from file or uses defaults)
await initializeConfig();

const hasOutputFlag = flags.output !== undefined;
const hasPromptFlag = flags.prompt !== undefined;
const isLiveMusic = flags.mode === 'live-music' || cmd === 'live-music';

if (hasOutputFlag && !hasPromptFlag && !cmd && !isLiveMusic) {
  console.error('Error: --prompt is required');
  process.exit(1);
}

// --- live-music mode: generateMusic + optional generateVisuals, write to --output, print paths ---
if (isLiveMusic) {
  const livePrompt = flags.prompt || cmdArgs[0];
  if (!livePrompt) {
    console.error('Error: --prompt is required for live-music');
    process.exit(1);
  }
  const liveOutDir = flags.output || path.join(process.env.HOME || '/tmp', '.liminal', 'output');
  fs.mkdirSync(liveOutDir, { recursive: true });

  // Load project config for live settings (MIDI, OSC, syncMode) - pass through only
  let liveConfig = null;
  try {
    liveConfig = await loadProjectConfig(process.cwd());
  } catch (_) {}
  const liveOpts = liveConfig?.live || {};

  console.log('');
  console.log('🎵 Liminal: Live Music');
  console.log('📝 Prompt: "' + livePrompt + '"');
  console.log('📁 Output: ' + liveOutDir);
  if (liveOpts.oscHost || liveOpts.syncMode) {
    console.log('🔧 Live config: oscHost=' + (liveOpts.oscHost || '-') + ', syncMode=' + (liveOpts.syncMode || '-'));
  }
  console.log('');

  try {
    const musicResult = await generateMusic(livePrompt, { musicPlatform: 'strudel' });
    const strudelPath = path.join(liveOutDir, 'strudel.js');
    fs.writeFileSync(strudelPath, musicResult.code, 'utf-8');
    console.log('✅ Music: ' + strudelPath);

    const visualResult = await generateVisuals({ prompt: livePrompt, platform: 'hydra' });
    const hydraPath = path.join(liveOutDir, 'hydra.js');
    fs.writeFileSync(hydraPath, visualResult.code, 'utf-8');
    console.log('✅ Visuals: ' + hydraPath);
    console.log('');
  } catch (err) {
    console.error('❌ Error:', err.message);
    process.exit(1);
  }
  process.exit(0);
}

if (cmd === 'generate' || cmd === 'gen' || cmd === 'g' || flags.prompt) {
  prompt = flags.prompt || cmdArgs[0];
  if (!prompt) {
    console.error('Error: --prompt is required');
    process.exit(1);
  }
  if (flags.maxIterations) maxIterations = flags.maxIterations;
  if (flags.output) output = flags.output;
  
  const outDir = output || path.join(process.env.HOME || '/tmp', '.liminal', 'output');
  fs.mkdirSync(outDir, { recursive: true });

  console.log('');
  console.log('🎨 Liminal: Creative Coding Agent');
  console.log('📝 Prompt: "' + prompt + '"');
  console.log('🔄 Max iterations: ' + maxIterations);
  if (output) console.log('📁 Output: ' + output);
  console.log('');
  console.log('Generating:', prompt);
  console.log('');
  
  run(prompt, {
    maxIterations: maxIterations,
    output: outDir,
    project: 'cli-project',
    useSwarm: flags.useSwarm,
    swarmMode: flags.swarmMode,
    swarmConfig: flags.swarmRounds ? { maxRounds: flags.swarmRounds } : undefined,
  }).then(async (result) => {
    console.log('');
    console.log('✅ Generation complete!');
    console.log('📊 Iterations: ' + result.iterations);
    console.log('⏱️ Time: ' + (result.duration / 1000).toFixed(1) + 's');
    console.log('🎯 Reason: ' + result.reason);
    console.log('⭐ Quality score: ' + result.finalScore.toFixed(2));
    // Track in history
    await history.add(prompt);
    
    console.log('✅ Saved: ' + result.jsPath);
    if (result.htmlPath) console.log('✅ HTML: ' + result.htmlPath);
    if (result.zipPath) console.log('✅ Archive: ' + result.zipPath);
    console.log('');
  }).catch(err => {
    console.error('');
    console.error('❌ Error:', err.message);
    console.error('');
    process.exit(1);
  });
} 
else if (cmd === 'serve' || cmd === 's') {
  const port = cmdArgs[0] || 3456;
  const server = new PreviewServer();
  
  function findLatestSketch(dirs) {
    let latestSketch = null;
    let latestTime = 0;
    
    for (const dir of dirs) {
      if (!fs.existsSync(dir)) continue;
      
      const files = fs.readdirSync(dir, { recursive: true })
        .filter(f => f.endsWith('.js'))
        .map(f => ({ file: f, path: path.join(dir, f), stat: fs.statSync(path.join(dir, f)) }))
        .filter(({ stat }) => stat.isFile());
      
      for (const { file, path: fullPath, stat } of files) {
        if (stat.mtimeMs > latestTime) {
          latestTime = stat.mtimeMs;
          latestSketch = { file, path: fullPath };
        }
      }
    }
    return latestSketch;
  }
  
  const searchDirs = [
    path.join(process.env.HOME || '/tmp', '.liminal', 'output'),
    path.join(process.cwd(), 'gallery'),
  ];
  
  const latestSketch = findLatestSketch(searchDirs);
  let sketchCode = '';
  
  if (latestSketch) {
    sketchCode = fs.readFileSync(latestSketch.path, 'utf-8');
    console.log('📄 Loading sketch:', latestSketch.file);
  } else {
    console.log('⚠️  No sketches found. Generate one first:');
    console.log('   liminal --prompt "your idea"');
  }
  
  server.serveSketch(sketchCode);
  server.start(port).then(() => {
    console.log('✅ Server running on http://localhost:' + port);
  }).catch(err => {
    console.error('❌ Error starting server:', err.message);
    process.exit(1);
  });
}
else if (cmd === 'compost') {
  // Check for dual-model configuration
  let llm;
  let fastLLM;
  let modelRouter;

  // Check if dual-model flags are provided
  const hasDualModelFlags = flags.fastModel || flags.powerfulModel || flags.routingMode;

  if (hasDualModelFlags) {
    // Dual-model mode: create ModelRouter with two LLM clients
    const fastModelName = flags.fastModel || 'qwen3.5:9b';
    const powerfulModelName = flags.powerfulModel || 'qwen3:30b-a3b';
    const routingMode = flags.routingMode || 'cascade';
    const confidenceThreshold = flags.confidenceThreshold ?? 0.8;

    console.log(`[Compost] Dual-model mode:`);
    console.log(`  Fast model: ${fastModelName}`);
    console.log(`  Powerful model: ${powerfulModelName}`);
    console.log(`  Routing mode: ${routingMode}`);
    console.log(`  Confidence threshold: ${confidenceThreshold}`);
    console.log('');

    // Create primary (fast) LLM client
    const primaryLLM = new LLMClient({
      provider: 'ollama',
      baseUrl: process.env.LIMINAL_LLM_BASE_URL || 'http://localhost:11434',
      model: fastModelName,
    });

    // Create secondary (powerful) LLM client
    const secondaryLLM = new LLMClient({
      provider: 'ollama',
      baseUrl: process.env.LIMINAL_LLM_BASE_URL || 'http://localhost:11434',
      model: powerfulModelName,
    });

    // Create ModelRouter
    modelRouter = new ModelRouter(primaryLLM, secondaryLLM, {
      primary: {
        provider: 'ollama',
        model: fastModelName,
        temperature: 0.7,
        maxTokens: 2000,
      },
      secondary: {
        provider: 'ollama',
        model: powerfulModelName,
        temperature: 0.7,
        maxTokens: 2000,
      },
      routing: {
        mode: routingMode,
        confidenceThreshold,
        primaryConcurrency: 8,
        secondaryConcurrency: 4,
      },
    });

    // Use the router as the main LLM
    llm = modelRouter;
    fastLLM = primaryLLM; // For backward compatibility with fastLLM parameter
  } else {
    // Single-model mode (original behavior)
    llm = new LLMClient();
    fastLLM = new LLMClient({ provider: 'lmstudio' });
  }

  const action = parseArgs(process.argv.slice(2));
  const mill = new CompostMill(llm, { soupEnabled: true, fastLLM, modelRouter });
  await execute(action, mill).catch(err => {
    console.error('Compost error:', err.message);
    process.exit(1);
  });
}
else if (cmd === 'list' || cmd === 'ls') {
  const outDir = path.join(process.env.HOME || '/tmp', '.liminal', 'output');
  console.log('📁 Sketches:');
  if (fs.existsSync(outDir)) {
    fs.readdirSync(outDir).filter(f => f.endsWith('.js')).forEach(f => console.log('  ' + f));
  } else {
    console.log('  (none yet)');
  }
}
else if (cmd === 'composite') {
  const specPath = flags.spec;
  const outputPath = flags.output;

  if (!specPath) {
    console.error('Error: --spec is required (path to composition JSON file)');
    process.exit(1);
  }
  if (!outputPath) {
    console.error('Error: --output is required (output video path)');
    process.exit(1);
  }

  const { Compositor } = await import('../dist/composite/Compositor.js');

  try {
    const specJson = fs.readFileSync(specPath, 'utf-8');
    const spec = JSON.parse(specJson);

    const compositor = new Compositor();
    compositor.validateSpec(spec);

    console.log('🎬 Compositing video...');
    console.log(`  Layers: ${spec.layers.length}`);
    console.log(`  Resolution: ${spec.width}x${spec.height}`);
    console.log(`  Duration: ${spec.duration}s @ ${spec.fps}fps`);

    await compositor.composite(spec, outputPath);

    console.log('✅ Composited video saved to: ' + outputPath);
  } catch (err) {
    console.error('❌ Compositing failed:', err.message);
    process.exit(1);
  }
}
else if (cmd === 'chat') {
  // Chat command - conversational creative coding mode
  chatCommand({ verbose: flags.verbose || false }).catch(err => {
    console.error('Chat error:', err.message);
    process.exit(1);
  });
}
else {
  console.error('Error: --prompt is required');
  console.error('');
  console.error('Run "liminal --configure" to set up LM Studio');
  console.error('Or use: liminal --prompt "your idea"');
  process.exit(1);
}
