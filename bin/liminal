    console.log(`  Pairs: ${model.pairCount}`);
    console.log(`  Training agreement: ${(model.trainingAgreement * 100).toFixed(1)}%`);
    console.log(`  Quality weight: ${model.qualityWeight.toFixed(3)}`);
