else if (cmd === 'report' && cmdArgs[0] === 'archive') {
  const { LiminalFS } = await import('../dist/fs/index.js');
  const { EmergenceHooks } = await import('../dist/emergence/index.js');
  const { EmergenceScorecard } = await import('../dist/evaluation/EmergenceScorecard.js');
  const { NicheQuotaPolicy } = await import('../dist/autonomy/NicheQuotaPolicy.js');

  const liminalFs = LiminalFS.open(process.cwd());
  try {
    const hooks = new EmergenceHooks(liminalFs);
    const archive = hooks.getArchive();
    const stats = archive.getStats();
    const elites = archive.getAllElites();
    const cells = archive.getAllCells();
    const scorecard = new EmergenceScorecard();
    const nichePolicy = new NicheQuotaPolicy();

    console.log('');
    console.log('=== Archive Report ===');
    console.log(`  Cells: ${stats.totalCells}  Elites: ${stats.totalElites}  Near-elites: ${stats.totalNearElites}`);
    console.log(`  Average quality: ${stats.avgQuality.toFixed(3)}`);

    const balance = nichePolicy.getBalanceScore(cells);
    console.log(`  Niche balance: ${(balance * 100).toFixed(1)}%`);

    if (elites.length > 0) {
      console.log('');
      console.log('  Top artifacts by quality:');
      const sorted = [...elites].sort((a, b) => b.qualityScore - a.qualityScore).slice(0, 5);
      for (const e of sorted) {
        const card = scorecard.score(e.signals);
        console.log(`    ${e.id}  q=${e.qualityScore.toFixed(2)}  composite=${card.overall.score.toFixed(2)} [${card.overall.grade}]  ${e.lineage.provenance}`);
      }

      console.log('');
      console.log('  Signal averages:');
      const avgNovelty = elites.reduce((s, e) => s + e.signals.novelty, 0) / elites.length;
      const avgStructure = elites.reduce((s, e) => s + e.signals.structure, 0) / elites.length;
      const avgTemporal = elites.reduce((s, e) => s + e.signals.temporalRichness, 0) / elites.length;
      const avgFertility = elites.reduce((s, e) => s + e.signals.fertility, 0) / elites.length;
      console.log(`    Novelty: ${avgNovelty.toFixed(3)}  Structure: ${avgStructure.toFixed(3)}  Temporal: ${avgTemporal.toFixed(3)}  Fertility: ${avgFertility.toFixed(3)}`);
    }
    console.log('');
  } finally {
    liminalFs.close();
  }
  process.exit(0);
}
