#!/usr/bin/env node
import dotenv from "dotenv";
dotenv.config();

import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

const binDir = path.dirname(fileURLToPath(import.meta.url));
const repoRoot = path.join(binDir, '..');
const packageJson = JSON.parse(fs.readFileSync(path.join(repoRoot, 'package.json'), 'utf-8'));
const args = process.argv.slice(2);

// Parse flags
const flags = {};
let cmd = null;
let cmdArgs = [];
let prompt = null;
let maxIterations = 3;
let output = null;

for (let i = 0; i < args.length; i++) {
  const arg = args[i];
  if (arg === '--help' || arg === '-h') {
    flags.help = true;
  } else if (arg === '--version') {
    flags.version = true;
  } else if (arg === '--prompt' || arg === '-p') {
    flags.prompt = args[++i];
  } else if (arg === '--max-iterations' || arg === '-m') {
    flags.maxIterations = parseInt(args[++i]);
  } else if (arg === '--output' || arg === '-o') {
    flags.output = args[++i];
  } else if (arg === '--input' || arg === '-f') {
    flags.input = args[++i];
  } else if (arg === '--provider') {
    flags.provider = args[++i];
  } else if (arg === '--model') {
    flags.model = args[++i];
  } else if (arg === '--configure') {
    flags.configure = true;
  } else if (arg === '--recent') {
    const nextArg = args[i + 1];
    if (nextArg && !nextArg.startsWith('-') && !isNaN(parseInt(nextArg))) {
      flags.recent = parseInt(args[++i]);
    } else {
      flags.recent = 10;
    }
  } else if (arg === '--favorite') {
    flags.favorite = args[++i];
  } else if (arg === '--favorites') {
    flags.favorites = true;
  } else if (arg === '--interactive' || arg === '-i') {
    flags.interactive = true;
  } else if (arg === '--mode') {
    flags.mode = args[++i];
  } else if (arg === '--use-swarm') {
    flags.useSwarm = true;
  } else if (arg === '--swarm-mode') {
    flags.swarmMode = args[++i];
  } else if (arg === '--swarm-rounds') {
    flags.swarmRounds = parseInt(args[++i]);
  } else if (arg === '--fast-model') {
    flags.fastModel = args[++i];
  } else if (arg === '--candidate') {
    flags.candidate = args[++i];
  } else if (arg === '--to') {
    flags.to = args[++i];
  } else if (arg === '--powerful-model') {
    flags.powerfulModel = args[++i];
  } else if (arg === '--routing-mode') {
    flags.routingMode = args[++i];
  } else if (arg === '--confidence-threshold') {
    flags.confidenceThreshold = parseFloat(args[++i]);
  } else if (arg === '--spec') {
    flags.spec = args[++i];
  } else if (arg === '--voice') {
    flags.voice = true;
  } else if (arg === '--voice-file') {
    flags.voiceFile = args[++i];
  } else if (arg === '--aesthetic') {
    flags.aesthetic = args[++i];
  } else if (arg === '--aesthetic-config') {
    flags.aestheticConfig = args[++i];
  } else if (arg === '--intuition') {
    flags.intuition = true;
  } else if (arg === '--consolidate') {
    flags.consolidate = true;
  } else if (arg === '--error') {
    flags.error = args[++i];
  } else if (arg === '--test-failures') {
    flags.testFailures = true;
  } else if (arg === '--test-file') {
    flags.testFile = args[++i];
  } else if (arg === '--dry-run') {
    flags.dryRun = true;
  } else if (arg === '--force') {
    flags.force = true;
  } else if (arg === '--gates-passed') {
    flags.gatesPassed = true;
  } else if (arg === '--confirm') {
    flags.confirm = args[++i];
  } else if (arg.startsWith('--confirm=')) {
    flags.confirm = arg.split('=')[1];
  } else if (arg === '--verbose' || arg === '-v') {
    flags.verbose = true;
  } else if (arg === '--script-only') {
    flags.scriptOnly = true;
  } else if (arg === '--spec-only') {
    flags.specOnly = true;
  } else if (!arg.startsWith('-')) {
    if (cmd === null) { cmd = arg; } else { cmdArgs.push(arg); }
  }
}


function isIsolatedWorktree(cwd = process.cwd()) {
  return cwd.includes(`${path.sep}.worktrees${path.sep}`)
    || cwd.includes(`${path.sep}.claude${path.sep}worktrees${path.sep}`);
}

function summarizeSession(session) {
  return {
    status: session.status,
    exitReason: session.exitReason,
    startTime: session.startTime,
    endTime: session.endTime,
    stepCount: session.stepCount,
    mutatedFiles: Array.from(session.mutatedFiles || []),
    successfulMutatedFiles: Array.from(session.successfulMutatedFiles || []),
    exploredPaths: Array.from(session.exploredPaths || []),
    messages: (session.messages || []).map((message) => ({
      role: message.role,
      content: typeof message.content === 'string' ? message.content.slice(0, 4000) : message.content,
      toolCall: message.toolCall,
      toolResult: message.toolResult,
    })),
  };
}

function printHelp() {
  console.log('');
  console.log('🎨 Liminal: Creative Coding Agent');
  console.log('');
  console.log('USAGE:');
  console.log('  liminal [options] <command> [args]');
  console.log('  liminal "natural language prompt"');
  console.log('');
  console.log('COMMANDS:');
  console.log('  <prompt>                    Natural-language creative request (no magic verb required)');
  console.log('  generate, gen, g <prompt>   Create art/code from prompt');
  console.log('  tui                         Launch natural language TUI (Meta-Harness)');
  console.log('  bridge [port]               Start TUI bridge server (default: 3000)');
  console.log('  studio                     Launch GUI workbench (backend + browser app)');
  console.log('  bubbletea [port]            Launch Bubble Tea operator cockpit with bridge');
  console.log('  operator [port]             Alias for Bubble Tea operator cockpit');
  console.log('  serve, s [port]             Start preview server (default: 3456)');
  console.log('  list, ls                    Show saved sketches');
  console.log('  compost <subcommand>        Compost Mill: add, digest, soup, seeds, status');
  console.log('  composite                   Analyze composition spec and generate layer plan');
  console.log('  chat                        Start conversational creative coding mode');
  console.log('  git <subcommand>            Git integration: status, log, diff, branch, commit, init');
  console.log('  fix <file|description>      Auto-fix code issues with LLM assistance');
  console.log('  consolidate                 Run memory consolidation (L3→L2 compression)');
  console.log('  ledger <subcommand>         Task ledger: list, show, run, verify, accept, reject, status');
  console.log('  self-improve gauntlet       Run headless self-improvement reflex/capability gauntlet');
  console.log('  improve <scan|run>          Diagnose repair, hardening, and optimization proposals');
  console.log('  quality <subcommand>       Quality gate: run, gate');
  console.log('  market status              Show honest market readiness status');
  console.log('  archive <subcommand>      Archive: inspect, lineage, branch, list');
  console.log('  preferences <subcommand>  Preferences: export, stats');
  console.log('  report cognition           Show creative body and cognitive architecture atlas');
  console.log('');
  console.log('OPTIONS:');
  console.log('  --prompt, -p <text>         Prompt for generation');
  console.log('  --max-iterations, -m <num>  Max iterations (default: 3)');
  console.log('  --output, -o <path>         Output directory');
  console.log('  --provider <name>           LLM provider (lmstudio, inception, ollama)');
  console.log('  --model <name>              Model name');
  console.log('  --configure                 Set up LM Studio config');
  console.log('  --recent [n]                Show recent prompts (default: 10)');
  console.log('  --favorite <prompt>         Add prompt to favorites');
  console.log('  --favorites                 List favorite prompts');
  console.log('  --interactive, -i           Interactive TUI mode');
  console.log('  --mode <mode>              Mode: live-music (generate Strudel/Hydra to --output)');
  console.log('  --use-swarm                Use Liminal swarm (7-persona Ollama) for generation');
  console.log('  --swarm-mode <mode>        Swarm mode: competitive, hybrid, ring, mesh (default: hybrid)');
  console.log('  --swarm-rounds <num>       Max swarm rounds (default: 10)');
  console.log('  --fast-model <name>        Primary/fast model for dual-mode (e.g., qwen3.5:9b)');
  console.log('  --powerful-model <name>     Secondary/powerful model (e.g., qwen3:30b-a3b)');
  console.log('  --routing-mode <mode>       Dual-model routing: cascade, speculative, ensemble, specialized');
  console.log('  --confidence-threshold <n>  Cascade escalation threshold (0-1, default: 0.8)');
  console.log('  --gates-passed              For improve scan: report improve mode after external gates pass');
  console.log('  --verbose, -v               Verbose output');
  console.log('  --voice                     Enable voice-driven visual mapping');
  console.log('  --voice-file <path>         Audio file for voice-to-visual analysis');
  console.log('  --aesthetic <preset>        Aesthetic guardrail preset (lenient|moderate|strict)');
  console.log('  --aesthetic-config <json>   Aesthetic guardrail configuration');
  console.log('  --intuition                 Enable intuition scoring dimension');
  console.log('  --consolidate               Run memory consolidation (L3→L2 compression)');
  console.log('  --error <text>              Error description for fix command');
  console.log('  --test-failures             Auto-detect and fix test failures');
  console.log('  --test-file <path>          Fix based on specific test file pattern');
  console.log('  --dry-run                   Show what would be fixed without making changes');
  console.log('  --confirm <auto|ask|never>  Confirmation level for fix command (default: ask)');
  console.log('  --help, -h                  Show this help message');
  console.log('  --version                   Show version');
  console.log('');
  console.log('EXAMPLES:');
  console.log('  liminal "icebergs dancing in the sky"');
  console.log('  liminal --prompt "blue particles"');
  console.log('  liminal --prompt "red circles" --provider lmstudio');
  console.log('  liminal --configure');
  console.log('  liminal serve 3456');
  console.log('  liminal list');
  console.log('');
}

// Handle --help flag (global)
if (flags.help) {
  printHelp();
  process.exit(0);
}

// Handle --version flag
if (flags.version) {
  console.log(`Liminal v${packageJson.version}`);
  process.exit(0);
}

if (cmd === 'self-improve') {
  const subCmd = cmdArgs[0] || 'gauntlet';
  if (subCmd === 'gauntlet') {
    const { runSelfImprovementGauntlet } = await import('../dist/runtime-core/SelfImprovementReflexes.js');
    const report = runSelfImprovementGauntlet();
    console.log('');
    console.log('=== Self-improvement gauntlet ===');
    console.log(`Level: ${report.level}`);
    console.log(`Prompts: ${report.passed}/${report.total} passed`);
    console.log(`Organs: ${report.organsTouched.join(', ')}`);
    console.log('');
    for (const result of report.results) {
      console.log(`${result.status === 'pass' ? 'PASS' : 'FAIL'} ${result.id}`);
      console.log(`  domain=${result.domain} focus=${result.fileHint}`);
      console.log(`  reflex=${result.recommendedReflex.nextAction} organs=${result.organs.join(', ')}`);
    }
    if (flags.output) {
      fs.writeFileSync(flags.output, `${JSON.stringify(report, null, 2)}\n`, 'utf-8');
      console.log('');
      console.log(`Wrote gauntlet report: ${flags.output}`);
    }
    console.log('');
    process.exit(report.failed === 0 ? 0 : 1);
  }
  console.error('Usage: liminal self-improve gauntlet [--output report.json]');
  process.exit(1);
}

// Keep improvement scans on a narrow startup path. The general CLI initializes
// provider config, guardrails, and the Meta-Harness; scan gates need to observe
// the repo without inheriting those runtime side effects.
if (cmd === 'improve') {
  const subCmd = cmdArgs[0] || 'scan';
  const {
    collectRepositoryOpportunityEvidence,
    formatOpportunityReport,
    scanGreenSystemOpportunities,
  } = await import('../dist/improvement/OpportunityScanner.js');
  const evidence = collectRepositoryOpportunityEvidence(process.cwd());
  if (flags.gatesPassed) {
    evidence.gates = [
      { name: 'build', status: 'pass', command: 'pnpm build', detail: 'caller asserted after running release gates' },
      { name: 'lint', status: 'pass', command: 'pnpm lint', detail: 'caller asserted after running release gates' },
      { name: 'fast tests', status: 'pass', command: 'pnpm test:ci:fast', detail: 'caller asserted after running release gates' },
      { name: 'slow tests', status: 'pass', command: 'pnpm test:ci:slow', detail: 'caller asserted after running release gates' },
      { name: 'go tests', status: 'pass', command: 'cd bubbletea && go test ./...', detail: 'caller asserted after running release gates' },
    ];
  }
  const report = scanGreenSystemOpportunities(evidence);

  if (subCmd === 'scan') {
    const outputText = formatOpportunityReport(report);
    console.log('');
    console.log(outputText);
    console.log('');
    if (flags.output) {
      fs.writeFileSync(flags.output, `${JSON.stringify(report, null, 2)}\n`, 'utf-8');
      console.log(`Wrote improvement report: ${flags.output}`);
    }
    process.exit(0);
  }

  if (subCmd === 'run') {
    const proposalId = cmdArgs[1];
    if (!proposalId) {
      console.error('Usage: liminal improve run <proposal-id>');
      process.exit(1);
    }

    const proposal = report.proposals.find((item) => item.id === proposalId);
    if (!proposal) {
      console.error(`Unknown proposal: ${proposalId}`);
      console.error('Run `liminal improve scan` to see current proposals.');
      process.exit(1);
    }

    const inWorktree = isIsolatedWorktree();
    if (!inWorktree && process.env.LIMINAL_ALLOW_MAIN_WORKTREE_IMPROVE !== '1') {
      console.error('Refusing to mutate the main worktree. Create an isolated worktree, then rerun this command there.');
      console.error('Override only for deliberate local experiments: LIMINAL_ALLOW_MAIN_WORKTREE_IMPROVE=1');
      process.exit(2);
    }

    const { LLMModeSelfImprovementRuntime } = await import('../dist/runtime-core/SelfImprovementRuntime.js');
    const { LLMClient } = await import('../dist/llm/LLMClient.js');
    const runtime = new LLMModeSelfImprovementRuntime();
    const llm = new LLMClient({ role: 'harness' });
    const description = [
      `Run type: ${report.runType}`,
      `Proposal: ${proposal.title}`,
      `Category: ${proposal.category}`,
      `Evidence: ${proposal.evidence.join('; ')}`,
      `Measurable target: ${proposal.measurableTarget}`,
      `Expected verification: ${proposal.expectedVerification.join(' && ')}`,
      'Produce a reviewable patch and verification report. Do not auto-merge.',
    ].join('\n');
    const result = await runtime.run({ llm, description });

    console.log('');
    console.log('=== Self-healing run complete ===');
    console.log(`  Task: ${result.taskId}`);
    console.log(`  Model: ${result.modelName}`);
    console.log(`  Status: ${result.session.status}`);
    console.log(`  Steps: ${result.session.stepCount}`);
    console.log('');
    process.exit(result.session.status === 'success' ? 0 : 1);
  }

  console.error('Usage: liminal improve <scan|run>');
  process.exit(1);
}


if (cmd === 'report' && cmdArgs[0] === 'cognition') {
  const { CognitiveArchitectureAtlas } = await import('../dist/reporting/index.js');
  const atlas = new CognitiveArchitectureAtlas();
  console.log('');
  console.log(atlas.format(atlas.build()));
  console.log('');
  process.exit(0);
}

const [
  { run, PreviewServer, generateMusic, generateVisuals, metaHarness },
  { getEffectiveConfig, saveConfig, loadProjectConfig },
  { PromptHistory },
  { InteractiveMode },
  { CompostMill },
  { parseArgs, execute },
  { handleGitCommand },
  { LLMClient },
  { ModelRouter },
  { chatCommand },
  { commandPrompt, inferNaturalLanguagePrompt, isSelfImprovementPrompt },
  { writeCliCognitiveReceipt },
  { collectRepositoryMarketReadinessStatus, formatMarketReadinessStatus },
] = await Promise.all([
  import('../dist/index.js'),
  import('../dist/config/ConfigLoader.js'),
  import('../dist/config/PromptHistory.js'),
  import('../dist/tui/InteractiveMode.js'),
  import('../dist/compost/CompostMill.js'),
  import('../dist/compost/cli.js'),
  import('../dist/git/index.js'),
  import('../dist/llm/LLMClient.js'),
  import('../dist/compost/ModelRouter.js'),
  import('../dist/chat/commands/chat.js'),
  import('../dist/cli/PromptArgs.js'),
  import('../dist/cli/CognitiveReceiptReporter.js'),
  import('../dist/market/MarketReadinessStatus.js'),
]);

// Initialize Meta-Harness only after cheap help/version fast paths have exited.
metaHarness.initialize();

// Initialize guardrail system (shadow mode + telemetry)
const { initializeGuardrailSystem } = await import('../dist/guardrails/index.js');
const guardrailSystem = initializeGuardrailSystem({ shadowMode: true, telemetry: true });

// Load config and set env vars for LLMClient to pick up
async function initializeConfig() {
  const config = await getEffectiveConfig(undefined, process.cwd());
  
  // Set env vars so LLMClient picks them up
  // Note: provider is no longer used - we use baseUrl + model directly
  // Only set if not already set in environment (respect user env vars)
  if (config.baseUrl && !process.env.LIMINAL_LLM_BASE_URL) process.env.LIMINAL_LLM_BASE_URL = config.baseUrl;
  // Propagate model — auto-detect from /v1/models only works for local LM Studio;
  // remote providers (MiniMax, OpenRouter, etc.) need an explicit model name.
  if (config.model && !process.env.LIMINAL_LLM_MODEL) process.env.LIMINAL_LLM_MODEL = config.model;
  if (config.apiKey && !process.env.LIMINAL_LLM_API_KEY) process.env.LIMINAL_LLM_API_KEY = config.apiKey;
  
  return config;
}

// Initialize prompt history
const history = new PromptHistory();

// Handle --configure flag
if (flags.configure) {
  console.log('');
  console.log('🎨 Liminal Configuration');
  console.log('');
  console.log('Setting up LM Studio config...');
  console.log('');
  
  const config = {
    defaultProvider: 'lmstudio',
    providers: {
      lmstudio: {
        baseUrl: 'http://localhost:1234/v1',
        model: 'local-model'
      }
    }
  };
  
  saveConfig(config).then(() => {
    console.log('✅ Config saved to ~/.liminal/config.json');
    console.log('');
    console.log('You can now run:');
    console.log('  liminal --prompt "your idea"');
    console.log('');
    process.exit(0);
  }).catch(err => {
    console.error('❌ Error saving config:', err.message);
    process.exit(1);
  });
  
  // Don't exit yet - wait for saveConfig
}

// Override config with CLI flags
if (flags.provider) {
  // --provider is now a convenience shorthand for setting baseUrl
  // The actual provider name is no longer stored - we use baseUrl + model directly
  const providerUrls = {
    'lmstudio': 'http://localhost:1234/v1',
    'inception': 'http://localhost:5000/v1',
    'ollama': 'http://localhost:11434/v1',  // Note: Ollama OpenAI-compatible endpoint
    'openai': 'https://api.openai.com/v1',
    'minimax': 'https://api.minimax.io/v1',
  };
  if (providerUrls[flags.provider]) {
    process.env.LIMINAL_LLM_BASE_URL = providerUrls[flags.provider];
    console.log(`[CLI] Using ${flags.provider} endpoint: ${providerUrls[flags.provider]}`);
  } else {
    console.warn(`[CLI] Unknown provider: ${flags.provider}. Use --base-url to set custom endpoint.`);
  }
}
if (flags.model) {
  process.env.LIMINAL_LLM_MODEL = flags.model;
}

// Handle --interactive flag
if (flags.interactive) {
  const mode = new InteractiveMode(history);
  try {
    const { prompt: interactivePrompt, options } = await mode.run();
    flags.prompt = interactivePrompt;
    if (options.provider) {
      process.env.LIMINAL_LLM_PROVIDER = options.provider;
    }
  } catch (err) {
    console.error('Interactive mode cancelled');
    process.exit(0);
  }
}

// Handle --recent flag
if (flags.recent) {
  const recent = await history.getRecent(flags.recent);
  console.log('');
  console.log('🕐 Recent Prompts:');
  console.log('');
  if (recent.length === 0) {
    console.log('  (none yet)');
  } else {
    recent.forEach((p, i) => console.log('  ' + (i + 1) + '. ' + p));
  }
  console.log('');
  process.exit(0);
}

// Handle --favorites flag
if (flags.favorites) {
  const favorites = await history.getFavorites();
  console.log('');
  console.log('⭐ Favorite Prompts:');
  console.log('');
  if (favorites.length === 0) {
    console.log('  (none yet)');
  } else {
    favorites.forEach((p, i) => console.log('  ' + (i + 1) + '. ' + p));
  }
  console.log('');
  process.exit(0);
}

// Handle --favorite flag (add to favorites)
if (flags.favorite) {
  await history.addFavorite(flags.favorite);
  console.log('');
  console.log('⭐ Added to favorites: "' + flags.favorite + '"');
  console.log('');
  process.exit(0);
}

// Initialize config (loads from file or uses defaults)
await initializeConfig();

// Load role definitions for LLMClient
await LLMClient.loadRoles();

const naturalLanguagePrompt = inferNaturalLanguagePrompt(cmd, cmdArgs);
if (naturalLanguagePrompt && flags.prompt === undefined) {
  flags.prompt = naturalLanguagePrompt;
}

if (naturalLanguagePrompt && flags.prompt && isSelfImprovementPrompt(flags.prompt)) {
  const { LLMModeSelfImprovementRuntime } = await import('../dist/runtime-core/SelfImprovementRuntime.js');
  const outDir = flags.output || path.join('.omx', 'self-improvement', new Date().toISOString().replace(/[:.]/g, '-'));
  fs.mkdirSync(outDir, { recursive: true });

  const runtime = new LLMModeSelfImprovementRuntime();
  const llm = new LLMClient({ role: 'harness' });
  const prepared = runtime.prepare({ llm, description: flags.prompt });
  const taskJsonPath = path.join(outDir, 'self-improvement-task.json');
  const taskMdPath = path.join(outDir, 'self-improvement-task.md');
  fs.writeFileSync(taskJsonPath, `${JSON.stringify(prepared.task, null, 2)}\n`, 'utf-8');
  fs.writeFileSync(taskMdPath, [
    '# Liminal Self-Improvement Task Packet',
    '',
    `Task: ${prepared.task.title}`,
    `Task ID: ${prepared.taskId}`,
    `Model: ${prepared.modelName}`,
    `Domain: ${prepared.task.domain}`,
    `Focus file: ${prepared.task.fileHint}`,
    '',
    '## Working set',
    ...prepared.task.workingSet.map((file) => `- ${file}`),
    '',
    '## Verification targets',
    ...prepared.task.verificationTargets.map((target) => `- ${target.tool}${target.pattern ? ` (${target.pattern})` : ''}: ${target.reason}`),
    '',
    '## Description',
    '',
    prepared.task.description,
    '',
  ].join('\n'), 'utf-8');

  console.log('');
  console.log('🛠️ Liminal: Self-improvement request');
  console.log('✅ Routed to self-improvement task preparation, not creative generation.');
  console.log(`📁 Output: ${outDir}`);
  console.log(`✅ Task JSON: ${taskJsonPath}`);
  console.log(`✅ Task Markdown: ${taskMdPath}`);
  console.log(`🎯 Focus file: ${prepared.task.fileHint}`);
  console.log(`🧪 Verification: ${prepared.task.verificationTargets.map((target) => target.tool).join(', ')}`);

  const executeRequested = flags.confirm === 'auto' || flags.force === true;
  if (!executeRequested) {
    console.log('ℹ️  Add --confirm auto to execute this bounded self-improvement task in an isolated worktree.');
    console.log('');
    process.exit(0);
  }

  if (!isIsolatedWorktree() && process.env.LIMINAL_ALLOW_MAIN_WORKTREE_IMPROVE !== '1') {
    console.error('❌ Refusing to execute self-improvement in the main worktree.');
    console.error('   Create an isolated worktree, then rerun with --confirm auto.');
    process.exit(2);
  }

  prepared.task.requiresMutation = true;
  console.log('🚀 Executing bounded self-improvement task...');
  const result = await prepared.execute();
  const sessionSummary = summarizeSession(result);
  const sessionJsonPath = path.join(outDir, 'self-improvement-session.json');
  const sessionMdPath = path.join(outDir, 'self-improvement-session.md');
  fs.writeFileSync(sessionJsonPath, `${JSON.stringify(sessionSummary, null, 2)}\n`, 'utf-8');
  fs.writeFileSync(sessionMdPath, [
    '# Liminal Self-Improvement Session',
    '',
    `Status: ${sessionSummary.status}`,
    `Exit reason: ${sessionSummary.exitReason || 'n/a'}`,
    `Steps: ${sessionSummary.stepCount}`,
    `Mutated files: ${sessionSummary.mutatedFiles.length > 0 ? sessionSummary.mutatedFiles.join(', ') : 'none'}`,
    `Successful mutated files: ${sessionSummary.successfulMutatedFiles.length > 0 ? sessionSummary.successfulMutatedFiles.join(', ') : 'none'}`,
    '',
    `Session JSON: ${sessionJsonPath}`,
    '',
  ].join('\n'), 'utf-8');
  console.log(`✅ Session JSON: ${sessionJsonPath}`);
  console.log(`✅ Session Markdown: ${sessionMdPath}`);
  console.log(`📊 Status: ${sessionSummary.status}`);
  console.log(`📊 Steps: ${sessionSummary.stepCount}`);
  console.log(`✏️  Mutated files: ${sessionSummary.mutatedFiles.length > 0 ? sessionSummary.mutatedFiles.join(', ') : 'none'}`);
  console.log('');
  process.exit(sessionSummary.status === 'success' ? 0 : 1);
}

