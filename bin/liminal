else if (cmd === 'composite') {
  const specPath = flags.spec;
  if (!specPath) {
    console.error('Usage: liminal composite --spec <spec.json> [--output <plan.json>]');
    process.exit(1);
  }

  const { Compositor } = await import('../dist/composite/Compositor.js');
  const { CompositionAnalyzer } = await import('../dist/composition/CompositionAnalyzer.js');
  try {
    const specJson = fs.readFileSync(specPath, 'utf-8');
    const spec = JSON.parse(specJson);
    const compositor = new Compositor();
    compositor.validateSpec(spec);

    console.log('Composition Spec Analysis');
    console.log(`  Layers: ${spec.layers?.length ?? 0}`);

    const analyzer = new CompositionAnalyzer();

    // Map compositor layer types (video/image/audio) to composition domain hints
    const typeToDomain = { video: 'p5', image: 'svg', audio: 'tone' };

    for (const layer of spec.layers ?? []) {
      const domainHint = typeToDomain[layer.type] || layer.type;
      const recommendations = await analyzer.analyze(`Generate ${domainHint} visual`);
      console.log(`  [${layer.type} -> ${domainHint}] confidence=${recommendations[0]?.confidence ?? 'n/a'} reason=${recommendations[0]?.reason ?? 'n/a'}`);
    }

    // Note: PromptEnhancer requires full composition Layer objects (with .type, .enabled,
    // .metadata.prompt) which compositor stub layers don't provide. Skip enhancement here
    // — it's available via the composition pipeline when layers are created through generators.

    const outputPath = flags.output;
    if (outputPath) {
      const plan = { spec, analyzedAt: new Date().toISOString(), layers: spec.layers?.length ?? 0 };
      fs.writeFileSync(outputPath, JSON.stringify(plan, null, 2));
      console.log(`  Plan written to: ${outputPath}`);
    }
    console.log('Done.');
    process.exit(0);
  } catch (err) {
    console.error('Composite analysis failed:', err.message);
    process.exit(1);
  }
}
