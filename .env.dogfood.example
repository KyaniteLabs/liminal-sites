# Dogfood Test Configuration
# Copy this file to .env.dogfood locally. Never commit real provider keys.

# Default provider for generation (Qwen via LM Studio)
LIMINAL_LLM_PROVIDER=lmstudio
LIMINAL_LLM_BASE_URL=http://localhost:1234/v1
LIMINAL_LLM_MODEL=qwen3-coder-next-reap-40b-a3b-i1

# Harness provider (Minimax m2.7)
# Do not commit real API keys here. Export MINIMAX_API_KEY locally.
LIMINAL_HARNESS_BASE_URL=https://api.minimax.io/v1
LIMINAL_HARNESS_MODEL=MiniMax-Text-01
LIMINAL_HARNESS_API_KEY=${MINIMAX_API_KEY}
LIMINAL_HARNESS_TEMPERATURE=0.2
LIMINAL_HARNESS_MAX_TOKENS=4096

# Enable all validators for dogfood tests
LIMINAL_ENABLE_ALL_VALIDATORS=true
LIMINAL_DOGFOOD_MODE=true
