      "better-sqlite3"
    ],
    "overrides": {
      "loader-utils": "2.0.4",
      "flatted": "3.4.2",
      "picomatch": "4.0.4",
      "brace-expansion@<5": "2.0.3",
      "lodash": "^4.18.0",
      "cookie": "0.7.0",
      "path-to-regexp": "8.4.0",
