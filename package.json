{
  "name": "liminal-ai",
  "version": "2.1.0",
  "description": "Creative coding agent with internal Ralph-Wiggum Loop and multi-domain intelligence",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Simon Gonzalez de Cruz",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KyaniteLabs/liminal.git"
  },
  "homepage": "https://github.com/KyaniteLabs/liminal#readme",
  "bugs": {
    "url": "https://github.com/KyaniteLabs/liminal/issues"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "postinstall": "node -e \"const fs=require('node:fs'); const cp=require('node:child_process'); const isCi=process.env.CI==='true'||process.env.CI==='1'; if(isCi){console.log('[postinstall] skipping build: CI install detected'); process.exit(0)} if(fs.existsSync('dist/index.js')){console.log('[postinstall] skipping build: dist/index.js already exists'); process.exit(0)} console.log('[postinstall] dist missing; building once for local/git install'); const r=cp.spawnSync('pnpm',['build'],{stdio:'inherit',shell:process.platform==='win32'}); process.exit(r.status ?? 1);\"",
    "prepack": "npm run build",
    "build": "tsc --incremental false",
    "test": "vitest run",
    "test:integration": "vitest run test/integration --coverage=false",
    "verify:integration": "npm run build && vitest run test/integration --coverage=false",
    "test:e2e": "vitest run test/e2e --coverage=false",
    "test:cloud": "RUN_CLOUD_MODEL_TESTS=1 vitest run test/e2e --coverage=false",
    "gui": "npm run build && node scripts/utils/start-studio.js",
    "gui:dev": "cd gui && npm run dev",
    "studio": "npm run gui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --cache --cache-location .eslintcache",
    "test:quality": "node scripts/testing/test-quality-check.mjs",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs src/",
    "tui": "npm run build && node scripts/start-bubbletea-tui.mjs",
    "dogfood:report": "npx tsx scripts/generate-dogfood-report.ts",
    "prepare": "git config core.hooksPath .githooks",
    "git:hygiene": "bash scripts/utils/git-hygiene.sh",
    "git:hygiene:dry": "bash scripts/utils/git-hygiene.sh --dry-run",
    "tui:ink": "node scripts/compat/ink-tui-compat.mjs",
    "tui:bridge": "npm run build && node scripts/start-bubbletea-tui.mjs --bridge-only",
    "proof:ml-value": "tsx scripts/proof/ml-value-proof.ts",
    "proof:launch-risk": "tsx scripts/proof/launch-risk-proof.ts",
    "proof:studio-smoke": "tsx scripts/proof/studio-smoke.ts",
    "test:ci:fast": "LIMINAL_CI_FAST=1 vitest run --coverage --pool=forks",
    "test:ci:slow": "LIMINAL_CI_SLOW=1 vitest run --pool=forks",
    "check:orphans": "bash scripts/check-orphans.sh",
    "proof:cognitive-loop": "tsx scripts/proof/cognitive-loop-proof.ts",
    "proof:model-assimilation": "tsx scripts/proof/model-assimilation-proof.ts",
    "proof:live-provider-smoke": "tsx scripts/proof/live-provider-smoke.ts",
    "proof:live-creative-domains": "tsx scripts/proof/live-creative-domain-execution.ts",
    "proof:live-model-assimilation": "tsx scripts/proof/model-assimilation-proof.ts --live",
    "proof:user-surfaces": "tsx scripts/proof/user-surfaces-e2e.ts",
    "proof:user-surface-observability": "tsx scripts/proof/user-surface-observability.ts",
    "proof:user-surface-controls": "tsx scripts/proof/user-surface-controls.ts",
    "proof:gui-bundle-budget": "tsx scripts/proof/gui-bundle-budget.ts",
    "qa:creative-domains": "node scripts/qa-creative-domains.mjs",
    "qa:creative-domains:static": "node scripts/qa-creative-domains.mjs --no-serve",
    "proof:visual-output-previews": "tsx scripts/proof/visual-output-preview-contract.ts",
    "proof:studio-launch-gauntlet": "node scripts/proof/studio-launch-gauntlet.mjs",
    "proof:route-performance": "tsx scripts/proof/route-performance-budget.ts"
  },
  "keywords": [
    "generative-art",
    "creative-coding",
    "p5js",
    "agent"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "typescript": "^5.3.3",
    "vite": "8.0.9",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@types/babel__traverse": "^7.28.0",
    "@xenova/transformers": "^2.17.2",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.8.0",
    "brace-expansion": "1.1.13",
    "clipboardy": "^5.3.1",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ink": "^5.2.1",
    "liminal-ai": "link:",
    "lodash": "^4.18.0",
    "neverthrow": "^8.2.0",
    "open": "^11.0.0",
    "p5": "^1.11.12",
    "path-to-regexp": "8.4.2",
    "picomatch": "4.0.4",
    "puppeteer": "^24.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "simple-git": "^3.33.0",
    "tsx": "^4.21.0",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "basic-ftp": "^5.3.0",
    "picomatch": "4.0.4",
    "protobufjs": "^7.5.5",
    "vite": "8.0.9"
  },
  "bin": {
    "liminal": "bin/liminal",
    "lim": "bin/liminal"
  },
  "optionalDependencies": {
    "@hyperframes/producer": "^0.4.3",
    "@revideo/2d": "^0.10.4",
    "@revideo/core": "^0.10.4",
    "@revideo/ffmpeg": "^0.10.4",
    "@revideo/renderer": "^0.10.4",
    "@revideo/ui": "^0.10.4",
    "@revideo/vite-plugin": "^0.10.4",
    "meyda": "^5.6.3",
    "music-metadata": "^11.12.3",
    "pitchfinder": "^2.3.4",
    "sharp": "^0.34.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "protobufjs",
      "puppeteer",
      "better-sqlite3"
    ],
    "overrides": {
      "loader-utils": "2.0.4",
      "flatted": "3.4.2",
      "picomatch": "4.0.4",
      "brace-expansion": "2.0.3",
      "lodash": "^4.18.0",
      "cookie": "0.7.0",
      "path-to-regexp": "8.4.0",
      "basic-ftp": "^5.3.0",
      "protobufjs": "^7.5.5",
      "vite": "8.0.9",
      "uuid": "^14.0.0"
    }
  }
}
