{
  "name": "liminal-ai",
  "version": "1.0.0",
  "description": "Creative coding agent with internal Ralph-Wiggum Loop and multi-domain intelligence",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "postinstall": "npm run build",
    "prepack": "npm run build",
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "gui": "node gui/start.js",
    "gui:dev": "cd gui && npm run dev",
    "gui:all": "concurrently -k -n b,v \"node gui/start.js\" \"npm run gui:dev\"",
    "gui:start": "node scripts/start-gui.js",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs src/",
    "benchmark": "node scripts/benchmark.js",
    "tui": "node --import tsx src/tui/index.tsx"
  },
  "keywords": [
    "generative-art",
    "creative-coding",
    "p5js",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.441",
    "@remotion/cli": "^4.0.441",
    "@remotion/renderer": "^4.0.441",
    "archiver": "^7.0.1",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ink": "^5.2.1",
    "p5": "^1.9.0",
    "puppeteer": "^24.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remotion": "^4.0.441",
    "tsx": "^4.21.0",
    "unified": "^11.0.5"
  },
  "overrides": {
    "loader-utils": ">=2.0.4",
    "flatted": ">=3.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "liminal": "bin/liminal"
  }
}
