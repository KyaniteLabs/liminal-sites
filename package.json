{
  "name": "atelier",
  "version": "1.0.0",
  "description": "Creative coding agent with internal Ralph-Wiggum Loop",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest test/integration",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest test/e2e",
    "gui": "node gui/start.js",
    "gui:dev": "cd gui && npm run dev",
    "gui:all": "concurrently -k -n b,v \"node gui/start.js\" \"npm run gui:dev\"",
    "gui:start": "node scripts/start-gui.js",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs src/",
    "benchmark": "node scripts/benchmark.js",
    "tui": "node --import tsx src/tui/index.tsx"
  },
  "keywords": [
    "generative-art",
    "creative-coding",
    "p5js",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "@types/react": "^18.3.28",
    "archiver": "^7.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ink": "^5.2.1",
    "p5": "^1.9.0",
    "puppeteer": "^24.37.5",
    "react": "^18.3.1",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.0"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "atelier": "bin/atelier"
  }
}