{
  "name": "liminal-sites",
  "version": "2.1.0",
  "description": "Living website evolution engine seeded from Liminal",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Simon Gonzalez de Cruz",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KyaniteLabs/liminal-sites.git"
  },
  "homepage": "https://kyanitelabs.github.io/liminal-sites/",
  "bugs": {
    "url": "https://github.com/KyaniteLabs/liminal-sites/issues"
  },
  "files": [
    "dist",
    "bin",
    "scripts/packaging",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "postinstall": "node scripts/packaging/postinstall.mjs",
    "prepack": "npm run build",
    "build": "tsc --incremental false",
    "test": "vitest run",
    "test:integration": "vitest run test/integration --coverage=false",
    "verify:integration": "npm run build && vitest run test/integration --coverage=false",
    "test:e2e": "vitest run test/e2e --coverage=false",
    "test:cloud": "RUN_CLOUD_MODEL_TESTS=1 vitest run test/e2e --coverage=false",
    "gui": "npm run build && node scripts/utils/start-studio.js",
    "engine:export": "tsx scripts/shitty-prompts/export.ts",
    "gui:dev": "cd gui && npm run dev",
    "desktop": "pnpm desktop:build && electron electron/main.cjs",
    "desktop:dev": "pnpm build && electron electron/main.cjs --dev",
    "desktop:build": "pnpm build && pnpm --dir gui build",
    "desktop:smoke": "node scripts/proof/electron-smoke.mjs",
    "desktop:package:mac": "pnpm desktop:build && node scripts/packaging/package-electron-mac.mjs",
    "studio": "npm run gui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --cache --cache-location .eslintcache",
    "security:secrets": "node scripts/ci/secret-scan.mjs",
    "check:examples": "node scripts/ci/smoke-composition-examples.mjs",
    "check:doc-links": "node scripts/ci/check-doc-links.mjs",
    "test:quality": "node scripts/testing/test-quality-check.mjs --baseline scripts/testing/test-quality-baseline.txt",
    "test:quality:strict": "node scripts/testing/test-quality-check.mjs --strict --baseline scripts/testing/test-quality-baseline.txt",
    "final-qa:test-quality": "pnpm test:quality:strict",
    "final-qa:surface": "node scripts/ci/final-qa-surface-gate.mjs",
    "gui:build": "pnpm --dir gui build",
    "bubbletea:test": "cd bubbletea && go test ./...",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs src/",
    "tui": "npm run build && node scripts/start-bubbletea-tui.mjs",
    "dogfood:report": "npx tsx scripts/generate-dogfood-report.ts",
    "prepare": "node scripts/packaging/prepare-package.mjs",
    "git:hygiene": "bash scripts/utils/git-hygiene.sh",
    "git:hygiene:dry": "bash scripts/utils/git-hygiene.sh --dry-run",
    "tui:ink": "node scripts/compat/ink-tui-compat.mjs",
    "tui:bridge": "npm run build && node scripts/start-bubbletea-tui.mjs --bridge-only",
    "proof:ml-value": "tsx scripts/proof/ml-value-proof.ts",
    "proof:git-ci-install": "node scripts/proof/git-ci-install.mjs",
    "proof:launch-risk": "tsx scripts/proof/launch-risk-proof.ts",
    "proof:studio-smoke": "tsx scripts/proof/studio-smoke.ts",
    "test:ci:fast": "LIMINAL_CI_FAST=1 vitest run --coverage --pool=forks",
    "test:ci:slow": "LIMINAL_CI_SLOW=1 vitest run --pool=forks",
    "check:orphans": "bash scripts/check-orphans.sh",
    "check:script-targets": "node scripts/ci/check-package-script-targets.mjs",
    "proof:cognitive-loop": "tsx scripts/proof/cognitive-loop-proof.ts",
    "proof:model-assimilation": "tsx scripts/proof/model-assimilation-proof.ts",
    "proof:live-provider-smoke": "tsx scripts/proof/live-provider-smoke.ts",
    "proof:live-creative-domains": "tsx scripts/proof/live-creative-domain-execution.ts",
    "proof:live-model-assimilation": "tsx scripts/proof/model-assimilation-proof.ts --live",
    "proof:user-surfaces": "tsx scripts/proof/user-surfaces-e2e.ts",
    "proof:user-surface-observability": "tsx scripts/proof/user-surface-observability.ts",
    "proof:user-surface-controls": "tsx scripts/proof/user-surface-controls.ts",
    "proof:gui-bundle-budget": "tsx scripts/proof/gui-bundle-budget.ts",
    "qa:creative-domains": "node scripts/qa-creative-domains.mjs",
    "qa:creative-domains:static": "node scripts/qa-creative-domains.mjs --no-serve",
    "proof:visual-output-previews": "tsx scripts/proof/visual-output-preview-contract.ts",
    "proof:living-sites-operator": "tsx scripts/proof/living-sites-operator-smoke.ts",
    "proof:living-sites-dogfood": "tsx scripts/proof/living-sites-dogfood.ts",
    "proof:living-sites-full-liminal": "tsx scripts/proof/living-sites-dogfood.ts",
    "proof:living-sites-reliability": "tsx scripts/proof/living-sites-reliability-sweep.ts",
    "proof:living-sites-sweep": "tsx scripts/proof/living-sites-operator-sweep.ts",
    "proof:studio-launch-gauntlet": "node scripts/proof/studio-launch-gauntlet.mjs",
    "proof:route-performance": "tsx scripts/proof/route-performance-budget.ts"
  },
  "keywords": [
    "website-evolution",
    "generative-design",
    "creative-coding",
    "mcp",
    "agent"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.1.0",
    "electron": "^42.0.1",
    "eslint": "^8.57.1",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "vite": "8.0.9",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/babel__traverse": "^7.28.0",
    "@xenova/transformers": "^2.17.2",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.10.0",
    "brace-expansion": "5.0.6",
    "clipboardy": "^5.3.1",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.2.0",
    "ink": "^5.2.1",
    "lodash": "^4.18.0",
    "neverthrow": "^8.2.0",
    "open": "^11.0.0",
    "p5": "^2.2.3",
    "path-to-regexp": "8.4.2",
    "picomatch": "4.0.4",
    "puppeteer": "^25.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "simple-git": "^3.36.0",
    "tsx": "^4.22.3",
    "typescript": "^5.3.3",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "basic-ftp": "5.3.1",
    "hono": "4.12.18",
    "ip-address": "10.2.0",
    "picomatch": "4.0.4",
    "protobufjs": "^7.5.8",
    "vite": "8.0.9",
    "@protobufjs/utf8": "1.1.1",
    "axios": "1.16.1",
    "qs": "6.15.2",
    "ws": "8.20.1"
  },
  "bin": {
    "liminal-sites": "bin/liminal",
    "liminal-sites-mcp": "bin/liminal-sites-mcp",
    "lsites": "bin/liminal",
    "liminal": "bin/liminal",
    "lim": "bin/liminal"
  },
  "optionalDependencies": {
    "@hyperframes/producer": "^0.6.70",
    "@revideo/2d": "^0.10.4",
    "@revideo/core": "^0.10.4",
    "@revideo/ffmpeg": "^0.10.4",
    "@revideo/renderer": "^0.10.4",
    "@revideo/ui": "^0.10.4",
    "@revideo/vite-plugin": "^0.10.4",
    "meyda": "^5.6.3",
    "music-metadata": "^11.12.3",
    "pitchfinder": "^2.3.4",
    "sharp": "^0.34.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "electron",
