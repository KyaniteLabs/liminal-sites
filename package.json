{
  "name": "liminal-ai",
  "version": "2.1.0",
  "description": "Creative coding agent with internal Ralph-Wiggum Loop and multi-domain intelligence",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Simon Gonzalez de Cruz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pastorsimon1798/liminal.git"
  },
  "homepage": "https://github.com/Pastorsimon1798/liminal#readme",
  "bugs": {
    "url": "https://github.com/Pastorsimon1798/liminal/issues"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "postinstall": "npm run build",
    "prepack": "npm run build",
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e",
    "gui": "node gui/start.js",
    "gui:dev": "cd gui && npm run dev",
    "gui:all": "concurrently -k -n b,v \"node gui/start.js\" \"npm run gui:dev\"",
    "gui:start": "node scripts/start-gui.js",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs src/",
    "benchmark": "node scripts/benchmark.js",
    "tui": "npx tsx src/tui/HarnessTUI.tsx",
    "dogfood:report": "npx tsx scripts/generate-dogfood-report.ts",
    "validate-docs": "node scripts/validate-version.js && node scripts/verify-file-refs.js",
    "audit-docs": "node scripts/audit-docs.js"
  },
  "keywords": [
    "generative-art",
    "creative-coding",
    "p5js",
    "agent"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "sharp": "0.34.5",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@remotion/bundler": "^4.0.445",
    "@remotion/cli": "^4.0.445",
    "@remotion/renderer": "^4.0.445",
    "@types/babel__traverse": "^7.28.0",
    "@xenova/transformers": "^2.17.2",
    "archiver": "^7.0.1",
    "clipboardy": "^5.3.1",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ink": "^5.2.1",
    "mdast": "^3.0.0",
    "open": "^11.0.0",
    "p5": "^1.11.12",
    "puppeteer": "^24.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remotion": "^4.0.445",
    "tsx": "^4.21.0",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "liminal": "bin/liminal",
    "lim": "bin/liminal"
  },
  "optionalDependencies": {
    "meyda": "^5.6.3",
    "music-metadata": "^11.12.3",
    "pitchfinder": "^2.3.4",
    "sharp": "^0.34.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "protobufjs",
      "puppeteer"
    ],
    "overrides": {
      "loader-utils": "2.0.4",
      "flatted": "3.4.2",
      "picomatch": "4.0.4",
      "brace-expansion": "2.0.3",
      "lodash": "4.18.0",
      "cookie": "0.7.0",
      "path-to-regexp": "8.4.0"
    }
  }
}
