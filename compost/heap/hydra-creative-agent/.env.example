# Hydra Creative Agent - Environment Variables
# Copy this file to .env and fill in your API keys

# Minimax API Key (required for Minimax LLM provider)
MINIMAX_API_KEY=your-minimax-api-key-here

# Anthropic API Key (required for Anthropic/Claude provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LM Studio Base URL (for local LM Studio server)
# For local machine: http://localhost:1234/v1
# For network machine: http://100.66.225.85:1234/v1
LMSTUDIO_BASE_URL=http://100.66.225.85:1234/v1

# Optional: Custom API base URLs
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
