#!/bin/bash
set -e

# Pre-commit hook for documentation validation + test verification + integration enforcement

echo "🔍 Running pre-commit checks..."

# --- Orphaned-file gate: new src/ files must be imported somewhere ---
for file in $(git diff --cached --name-only --diff-filter=A | grep '^src/.*\.ts$' || true); do
    basename=$(basename "$file" .ts)
    # Skip index.ts files and type definition files
    if [[ "$basename" == "index" ]]; then continue; fi
    if [[ "$basename" == *".d" ]]; then continue; fi

    # Count imports of this file from other files in src/ (path-based only, avoids symbol-name false positives)
    imports=$(grep -rE "from\s+.*/$basename|from\s+$basename|import\s+.*/$basename|import\s+$basename" src/ --include="*.ts" | grep -v "$file" | wc -l || true)

    if [ "$imports" -eq 0 ]; then
        if [ "${AGENT_SESSION:-}" = "1" ]; then
            echo "  WARNING (agent session): $file is not imported yet. Wire it up before merging."
        else
            echo ""
            echo "ERROR: $file is not imported anywhere in src/."
            echo "Orphaned files are not allowed. Wire it up or remove it before committing."
            echo ""
            exit 1
        fi
    fi
done

# --- Documentation checks ---
if git diff --cached --name-only | grep -q "docs/THE_BIBLE.md"; then
    echo "✓ THE_BIBLE.md updated"
else
    if git diff --cached --name-only | grep -q "^src/"; then
        echo "⚠️  WARNING: You modified src/ but not THE_BIBLE.md"
        echo "   Run: npm run validate-docs"
    fi
fi

# Run validation scripts
node scripts/analysis/validate-version.js --quiet || exit 1
node scripts/analysis/verify-file-refs.js --quiet || exit 1

# Run doc-validate if available (CI-mirrored check)
PROJECT_ROOT=$(git rev-parse --show-toplevel)
if [ -f "$HOME/.local/bin/doc-validate" ]; then
    "$HOME/.local/bin/doc-validate" "$PROJECT_ROOT" || {
        echo "❌ Documentation validation failed"
        exit 1
    }
fi

echo "✅ Documentation checks passed"

# --- Test verification for changed files ---
CHANGED_SRC=$(git diff --cached --name-only | grep "^src/.*\.ts$" | head -10)
if [ -n "$CHANGED_SRC" ]; then
    echo "🧪 Running tests for changed source files..."
    # vitest --changed runs only tests affected by changed files
    npx vitest run --changed --reporter=verbose --retry=2 --testTimeout=10000 2>&1 | tail -5
    VITEST_EXIT=${PIPESTATUS[0]}
    if [ $VITEST_EXIT -ne 0 ]; then
        if [ "${AGENT_SESSION:-}" = "1" ]; then
            echo "  WARNING: Tests failed but allowing commit (agent session). CI will validate."
        else
            echo "❌ Tests failed for changed files. Fix before committing."
            echo "   Run with --no-verify to skip (not recommended)."
            exit 1
        fi
    fi
    echo "✅ Changed file tests passed"
fi

echo "✅ All pre-commit checks passed"

# --- Stray file detection ---
# Warn about known stray file patterns. Warn-only (does not block commit).

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
STRAY_FOUND=false

if [ -n "$STAGED_FILES" ]; then
    # Pattern 1: Shell redirect artifacts (e.g., "1timeout:", "2timeout:")
    strays_redirect=$(echo "$STAGED_FILES" | grep -E '^[0-9]+[a-zA-Z]+:' || true)
    if [ -n "$strays_redirect" ]; then
        echo "⚠️  WARNING: Shell redirect artifacts staged for commit:"
        echo "$strays_redirect" | while read -r f; do echo "    - $f"; done
        STRAY_FOUND=true
    fi

    # Pattern 2: PNG files in root directory
    strays_png=$(echo "$STAGED_FILES" | grep -E '^[^/]+\.png$' || true)
    if [ -n "$strays_png" ]; then
        echo "⚠️  WARNING: PNG files in root directory staged for commit:"
        echo "$strays_png" | while read -r f; do echo "    - $f"; done
        STRAY_FOUND=true
    fi

    # Pattern 3: Files larger than 1MB in root directory
    for f in $STAGED_FILES; do
        if [ "$(dirname "$f")" = "." ]; then
            size=$(git cat-file -s ":$f" 2>/dev/null || echo 0)
            if [ "$size" -gt 1048576 ]; then
                echo "⚠️  WARNING: Large file staged in root: $f ($(( size / 1048576 ))MB)"
                STRAY_FOUND=true
            fi
        fi
    done

    if [ "$STRAY_FOUND" = true ]; then
        echo ""
        echo "  These look like stray artifacts. Unstage with: git reset HEAD <file>"
    fi
fi
